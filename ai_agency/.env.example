# Claude API
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-ME-WITH-YOUR-KEY
CLAUDE_MODEL=claude-sonnet-4-6
# Пресеты HQ (настройки панели /hq/settings.html): эконом и качество; баланс = CLAUDE_MODEL
# HQ_MODEL_ECONOMY=claude-3-5-haiku-20241022
# HQ_MODEL_QUALITY=claude-opus-4-1-20250805

# Telegram
TELEGRAM_BOT_TOKEN=000000000:REPLACE_ME_WITH_YOUR_BOT_TOKEN_FROM_BOTFATHER
TELEGRAM_OWNER_ID=000000000
TELEGRAM_CHANNEL_ID=@your_channel_or_leave_empty

# Сервер
HOST=0.0.0.0
PORT=8000
# true = только FastAPI + HQ; Telegram и планировщик не стартуют (удобно, если бот уже на VPS)
WEB_ONLY=false
# Сгенерировать через: openssl rand -hex 32
SECRET_KEY=replace-with-output-of-openssl-rand-hex-32
# Длинный случайный пароль (минимум 16 символов)
ADMIN_PASSWORD=set-a-long-random-password

# Опционально: Yandex Metrica
# YANDEX_METRIKA_OAUTH_TOKEN=your-yandex-oauth-token
# YANDEX_METRIKA_COUNTER_ID=12345678

# Публикация
AUTO_PUBLISH=false
DAILY_POST_TIME=09:00
TIMEZONE=Europe/Moscow
